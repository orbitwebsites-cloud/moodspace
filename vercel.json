{
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/auth.html", "destination": "/auth.html" },
    { "source": "/checkout.html", "destination": "/checkout.html" },
    { "source": "/dashboard.html", "destination": "/dashboard.html" },
    { "source": "/terms.html", "destination": "/terms.html" },
    { "source": "/privacy.html", "destination": "/privacy.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
